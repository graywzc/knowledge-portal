{
  "name": "knowledge-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Tree-structured knowledge portal over flat chat conversations",
  "scripts": {
    "app:start": "node --env-file=${ENV_FILE:-.env} server/index.js",
    "app:watch": "node --env-file=${ENV_FILE:-.env} --watch server/index.js",
    "seed": "node --env-file=${ENV_FILE:-.env} scripts/seed.js",
    "mtproto:once": "node --env-file=${ENV_FILE:-.env} scripts/mtproto-sync.js once",
    "mtproto:loop": "node --env-file=${ENV_FILE:-.env} scripts/mtproto-sync.js loop",
    "mtproto:reset-last-id": "node --env-file=${ENV_FILE:-.env} scripts/reset-last-id.js",
    "dev:all": "concurrently -n APP,INGEST -c blue,green \"npm run app:watch\" \"npm run mtproto:loop\"",
    "prod:all": "concurrently -n APP,INGEST -c blue,green \"npm run app:start\" \"npm run mtproto:loop\"",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "express": "^4.18.0",
    "input": "^1.0.1",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
